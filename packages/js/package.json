{
	"name": "@exstyle/js",
	"version": "1.0.0",
	"description": "リアルタイムで HTMLコード内 の ExStyleプロパティ を解析し、CSSコード と style要素 を生成するスクリプト。",
	"main": "dist/exstyle.js",
	"module": "dist/exstyle.mjs",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rollup -c rollup.config.mjs",
		"dev": "rollup -c rollup.config.mjs -w"
	},
	"keywords": [ "ExStyle", "JS" ],
	"author": "Nobuo Nakayama (Shimotsuki/nov-jp)",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nov-jp/exstyle.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@exstyle/core": "*"
	},
	"devDependencies": {
		"@rollup/plugin-commonjs": "^29.0.2",
		"@rollup/plugin-json": "^6.1.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-terser": "^1.0.0",
		"rollup": "^4.60.2"
	}
}
