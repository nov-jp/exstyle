{
	"name": "nov-jp/exstyle",
	"description": "ExStyle は、CSS のカスタムプロパティと属性セレクタを使用して、HTML の style属性 を限界突破させる、スタイリング・インフラを確立するためのメタ・フレームワークです。",
	"license": "MIT",
	"authors": [
		{
			"name": "Nobuo Nakayama",
			"email": "webmaster@shimotsuki.wwwxyz.jp"
		}
	],
	"repositories": [
		{
			"type": "path",
			"url": "packages/php",
			"options": {
				"symlink": true
			}
		}
	],
	"require": {
		"nov-jp/exstyle-php": "*"
	},
	"minimum-stability": "dev",
	"prefer-stable": true
}
